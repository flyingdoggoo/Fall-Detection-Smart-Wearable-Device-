# Cấu hình so sánh WEDA-FALL với data thu thập
# Script dùng file này: python/visualize_compare.py

# =====================
# WEDA (dataset/50Hz)
# =====================
WEDA_ACTIVITY=D01
WEDA_USER=U03
WEDA_RUN=R01

# =====================
# Collected (server/data/collected)
# =====================
# Cách 1 (ưu tiên cao nhất): chỉ định thẳng folder session
# Ví dụ:
#   D:\Workspace\Nam4\PBL5\server\data\collected\Normal\label0_2026-01-28T10-43-12
COLLECTED_SESSION_DIR=D:\Workspace\Nam4\PBL5\server\data\collected\Normal\label0_2026-01-28T12-07-44

# Cách 2: nếu COLLECTED_SESSION_DIR trống thì chọn session mới nhất theo label
# 0 = Normal, 1 = Fall, any = tự tìm trong cả 2
COLLECTED_LABEL=0

# =====================
# Tiền xử lý để so sánh
# =====================
# Resample về 50Hz bằng nội suy tuyến tính
RESAMPLE_WEDA=true
RESAMPLE_COLLECTED=false

# Low-pass (Hz). Để trống nếu không muốn lọc.
LOWPASS_CUTOFF_HZ=10

# DC removal (trừ mean từng trục).
# Khi test đặt yên: nên để false để thấy độ lớn accel ~ 9.8 m/s^2
COLLECTED_REMOVE_DC=false

# =====================
# Fine-tune WEDA (tùy chọn)
# =====================
WEDA_REMOVE_DC=true
WEDA_EXTRA_LOWPASS_HZ=
WEDA_MATCH_STD=false

# In log thống kê nhanh
VERBOSE=true
